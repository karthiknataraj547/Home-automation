{
  "name": "jarvis",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite --port 3000 --host",
    "build": "vite build",
    "preview": "vite preview",
    "pwa:build": "vite build",
    "electron:dev": "concurrently \"npm run dev\" \"electron . --dev\"",
    "electron:build": "npm run build && electron-builder build --win",
    "android:sync": "npm run build && cap sync",
    "android:build": "npm run android:sync && cd android && gradlew assembleDebug"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0"
  },
  "build": {
    "appId": "com.lukas.jarvis.app",
    "productName": "LUKAS Assistant",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "go2rtc.exe",
      "go2rtc.yaml",
      "package.json",
      "src/deviceKnowledgeBase.js"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
